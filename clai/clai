#!/usr/bin/env python3
import sys
import os
import json
import urllib.request
import urllib.error
import platform

def main():
    if len(sys.argv) < 2:
        print("Usage: clai <prompt>", file=sys.stderr)
        sys.exit(1)

    api_key = os.environ.get("OPENROUTER_API_KEY")
    if not api_key:
        print("Error: OPENROUTER_API_KEY not set", file=sys.stderr)
        sys.exit(1)

    prompt = " ".join(sys.argv[1:])
    os_name = "macOS" if platform.system() == "Darwin" else "Linux"

    system_prompt = (
        f"You are a terminal command assistant running on {os_name}. "
        "Return ONLY the exact shell command the user needs — no explanation, "
        "no markdown, no code fences, no punctuation before or after. "
        "Single line only. If multiple commands are needed, chain with && or ;."
    )

    payload = json.dumps({
        "model": "anthropic/claude-sonnet-4-6",
        "messages": [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": prompt}
        ],
        "max_tokens": 256,
        "temperature": 0
    }).encode()

    req = urllib.request.Request(
        "https://openrouter.ai/api/v1/chat/completions",
        data=payload,
        headers={
            "Authorization": f"Bearer {api_key}",
            "Content-Type": "application/json",
            "HTTP-Referer": "https://github.com/crispychris/clai",
            "X-Title": "clai"
        }
    )

    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            body = json.loads(resp.read())
        command = body["choices"][0]["message"]["content"].strip()
        print(command)
    except urllib.error.HTTPError as e:
        err = e.read().decode()
        print(f"API error {e.code}: {err}", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
